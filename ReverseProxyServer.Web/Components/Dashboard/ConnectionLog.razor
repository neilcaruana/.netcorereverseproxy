@using ReverseProxyServer.Web.Services
@using ReverseProxyServer.Data.DTO
@inject IJSRuntime JS
@inject IDashboardDataService DashboardService
@inject PortLookupService PortLookup

<div class="card shadow-sm">
    <div class="card-header bg-white py-2">
        <div class="d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-semibold">
                <i class="bi bi-list-ul me-2"></i>Connection Log
            </h6>
            <div class="d-flex align-items-center gap-2">
                <span class="text-muted small">
                    @if (PagedConnections != null)
                    {
                        <span>@PagedConnections.TotalCount.ToString("N0") total records</span>
                    }
                </span>
                @if (PagedConnections?.TotalPages > 1)
                {
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(!PagedConnections.HasPreviousPage ? "disabled" : "")">
                            <button class="page-link" @onclick="() => OnPageChanged.InvokeAsync(1)" disabled="@(!PagedConnections.HasPreviousPage)">
                                <i class="bi bi-chevron-double-left"></i>
                            </button>
                        </li>
                        <li class="page-item @(!PagedConnections.HasPreviousPage ? "disabled" : "")">
                            <button class="page-link" @onclick="() => OnPageChanged.InvokeAsync(CurrentPage - 1)" disabled="@(!PagedConnections.HasPreviousPage)">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>
                        @foreach (var pageNum in GetPageNumbers())
                        {
                            <li class="page-item @(pageNum == CurrentPage ? "active" : "")">
                                <button class="page-link" @onclick="() => OnPageChanged.InvokeAsync(pageNum)">@pageNum</button>
                            </li>
                        }
                        <li class="page-item @(!PagedConnections.HasNextPage ? "disabled" : "")">
                            <button class="page-link" @onclick="() => OnPageChanged.InvokeAsync(CurrentPage + 1)" disabled="@(!PagedConnections.HasNextPage)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                        <li class="page-item @(!PagedConnections.HasNextPage ? "disabled" : "")">
                            <button class="page-link" @onclick="() => OnPageChanged.InvokeAsync(PagedConnections.TotalPages)" disabled="@(!PagedConnections.HasNextPage)">
                                <i class="bi bi-chevron-double-right"></i>
                            </button>
                        </li>
                    </ul>
                }
                @if (PagedConnections?.SessionsWithData.Count > 0)
                {
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-secondary" @onclick="ExpandAll" disabled="@_isExpandingAll" title="Expand all">
                            @if (_isExpandingAll)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <i class="bi bi-arrows-expand"></i>
                            }
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="CollapseAll" title="Collapse all">
                            <i class="bi bi-arrows-collapse"></i>
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="card-body p-0 position-relative">
        @if (IsLoading && PagedConnections != null)
        {
            <div class="loading-overlay">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        @if (IsLoading && PagedConnections == null)
        {
            <div class="d-flex justify-content-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else if (PagedConnections?.Items.Any() == true)
        {
            <div class="table-responsive @(IsLoading ? "opacity-50" : "")" style="transition: opacity 0.2s ease;">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            @{
                                var columns = new (string Column, string Label, string? Style, bool Sortable)[]
                                {
                                    ("", "", "width: 30px;", false),
                                    (nameof(Connection.ConnectionTime), "Time", null, true),
                                    ("", "Session", null, false),
                                    (nameof(Connection.ProxyType), "Type", null, true),
                                    (nameof(Connection.RemoteAddress), "Remote IP", null, true),
                                    ("", "Status", "min-width: 90px; width: 90px;", false),
                                    ("", "Country", "width: 70px;", false),
                                    (nameof(Connection.RemotePort), "Port", null, true),
                                    ("", "", "width: 30px;", false),
                                    (nameof(Connection.LocalAddress), "Local Address", null, true),
                                    (nameof(Connection.LocalPort), "Port", null, true),
                                };
                            }
                            @foreach (var (col, label, style, sortable) in columns)
                            {
                                var activeColumn = Filter.SortColumn ?? nameof(Connection.ConnectionTime);
                                var isActive = sortable && activeColumn == col;

                                if (sortable)
                                {
                                    <th class="sortable-header @(isActive ? "sort-active" : "")"
                                        style="@style"
                                        @onclick="() => OnSortChanged.InvokeAsync(col)"
                                        title="Sort by @label">
                                        <span class="sort-label">
                                            @label
                                            <span class="sort-icon @SortIcon(col)"></span>
                                        </span>
                                    </th>
                                }
                                else
                                {
                                    <th style="@style">@label</th>
                                }
                            }
                        </tr>
                        <tr class="filter-row">
                            <td>
                                @if (Filter.HasAnyFilter)
                                {
                                    <button class="btn btn-link btn-sm p-0 text-danger" @onclick="ClearFilters" title="Clear all filters">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                }
                            </td>
                            <td></td>
                            <td></td>
                            <td>
                                <select class="form-select form-select-sm filter-input" value="@Filter.ProxyType" @onchange="e => ApplyFilter(f => f.ProxyType = e.Value?.ToString())">
                                    <option value="">All</option>
                                    <option value="Forward">Forward</option>
                                    <option value="HoneyPot">Honeypot</option>
                                </select>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm filter-input" placeholder="Filter..."
                                       value="@Filter.RemoteAddress" @onchange="e => ApplyFilter(f => f.RemoteAddress = e.Value?.ToString())" />
                            </td>
                            <td style="min-width: 90px;">
                                <select class="form-select form-select-sm filter-input" value="@Filter.IsBlacklisted" @onchange="e => ApplyFilter(f => f.IsBlacklisted = e.Value?.ToString())">
                                    <option value="">All</option>
                                    <option value="Yes">Blocked</option>
                                    <option value="No">Clean</option>
                                </select>
                            </td>
                            <td>
                                <button id="country-filter-btn" class="form-select form-select-sm filter-input text-start text-truncate" type="button"
                                        style="padding-right: 1.5rem;" @onclick="ToggleCountryPickerAsync" @onclick:stopPropagation="true">
                                    @if (string.IsNullOrEmpty(Filter.CountryCode))
                                    {
                                        <span class="text-muted">All</span>
                                    }
                                    else
                                    {
                                        @Filter.CountryCode
                                    }
                                </button>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm filter-input" placeholder="Filter..."
                                       value="@Filter.RemotePort" @onchange="e => ApplyFilter(f => f.RemotePort = e.Value?.ToString())" />
                            </td>
                            <td></td>
                            <td>
                                <input type="text" class="form-control form-control-sm filter-input" placeholder="Filter..."
                                       value="@Filter.LocalAddress" @onchange="e => ApplyFilter(f => f.LocalAddress = e.Value?.ToString())" />
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm filter-input" placeholder="Filter..."
                                       value="@Filter.LocalPort" @onchange="e => ApplyFilter(f => f.LocalPort = e.Value?.ToString())" />
                            </td>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var rowIndex = 0; }
                        @foreach (var conn in PagedConnections.Items)
                        {
                            var isExpanded = _expandedSessions.ContainsKey(conn.SessionId);
                            var hasData = PagedConnections.SessionsWithData.Contains(conn.SessionId);
                            rowIndex++;
                            var rid = rowIndex;
                            var ipAnchor = "ip-" + rid;
                            var rpAnchor = "rp-" + rid;
                            var lpAnchor = "lp-" + rid;
                            <tr class="@(isExpanded ? "table-active" : "")" @onclick="() => ToggleRowExpand(conn.SessionId)" style="cursor: pointer;">
                                <td class="text-center">
                                    @if (_loadingSessionId == conn.SessionId)
                                    {
                                        <span class="spinner-border spinner-border-sm text-primary"></span>
                                    }
                                    else if (hasData)
                                    {
                                        <span class="badge @(isExpanded ? "bg-primary" : "bg-primary-subtle text-primary border border-primary-subtle")" style="font-size:0.6rem;">
                                            <i class="bi @(isExpanded ? "bi-caret-down-fill" : "bi-caret-right-fill")"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-dash text-muted"></i>
                                    }
                                </td>
                                <td>
                                    <span class="fw-medium">@conn.ConnectionTime.ToString("MMM dd")</span>
                                    <span class="text-muted">@conn.ConnectionTime.ToString("HH:mm:ss")</span>
                                </td>
                                <td><code class="text-muted" style="font-size: 0.7rem;">@conn.SessionId?[..8]</code></td>
                                <td>
                                    @if (conn.ProxyType == "HoneyPot")
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-bullseye me-1"></i>Honeypot</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success"><i class="bi bi-arrow-right me-1"></i>Forward</span>
                                    }
                                </td>
                                <td><code id="@ipAnchor" role="button" class="text-primary" @onclick="() => ShowIPDetailsAsync(conn.RemoteAddress, ipAnchor)" @onclick:stopPropagation="true">@conn.RemoteAddress</code></td>
                                <td class="text-center">
                                    @if (PagedConnections.BlacklistedIPs.Contains(conn.RemoteAddress))
                                    {
                                        <span role="button" class="badge bg-danger-subtle text-danger border border-danger-subtle cursor-pointer"
                                              title="Blacklisted" @onclick="() => ShowIPDetailsAsync(conn.RemoteAddress, ipAnchor)" @onclick:stopPropagation="true">🏴‍☠️ Blocked</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (PagedConnections.CountryCodeMap.TryGetValue(conn.RemoteAddress, out var countryCode))
                                    {
                                        <span role="button" class="badge bg-light text-muted border cursor-pointer" title="@countryCode"
                                              @onclick="() => ShowIPDetailsAsync(conn.RemoteAddress, ipAnchor)" @onclick:stopPropagation="true">
                                            <img src="https://flagcdn.com/w20/@(countryCode.ToLowerInvariant()).png"
                                                 width="14" height="10" alt="@countryCode" loading="lazy" />
                                            @countryCode
                                        </span>
                                    }
                                </td>
                                <td><code id="@rpAnchor" role="button" class="text-primary" @onclick="() => ShowPortDetailsAsync(conn.RemotePort, rpAnchor)" @onclick:stopPropagation="true">@conn.RemotePort</code></td>
                                <td class="text-center text-muted"><i class="bi bi-arrow-right"></i></td>
                                <td><code>@conn.LocalAddress</code></td>
                                <td><code id="@lpAnchor" role="button" class="text-primary" @onclick="() => ShowPortDetailsAsync(conn.LocalPort, lpAnchor)" @onclick:stopPropagation="true">@conn.LocalPort</code></td>
                            </tr>
                            @if (isExpanded)
                            {
                                var sessionData = _expandedSessions[conn.SessionId];
                                <tr>
                                    <td colspan="11" class="bg-light p-0">
                                        <div class="p-2">
                                            @if (sessionData?.Any() == true)
                                            {
                                                @foreach (var data in sessionData)
                                                {
                                                    <div class="connection-data-record mb-2">
                                                        <div class="d-flex align-items-center mb-1">
                                                            @if (data.CommunicationDirection == "Incoming")
                                                            {
                                                                <span class="badge bg-info me-2"><i class="bi bi-arrow-down-left me-1"></i>Incoming</span>
                                                                <small class="text-muted">Remote → Local</small>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-success me-2"><i class="bi bi-arrow-up-right me-1"></i>Outgoing</span>
                                                                <small class="text-muted">Local → Remote</small>
                                                            }
                                                        </div>
                                                        <div class="connection-data-pre bg-dark rounded position-relative">
                                                            <pre class="text-light p-2 mb-0">@data.Data</pre>
                                                            <button class="btn btn-sm position-absolute @(_copiedDataId == data.Id ? "btn-success" : "btn-outline-light opacity-50")"
                                                                    style="top: 4px; right: 4px; padding: 0.15rem 0.35rem; font-size: 0.6rem; z-index: 1;"
                                                                    @onclick:stopPropagation="true"
                                                                    @onclick="() => CopyDataAsync(data)"
                                                                    title="Copy to clipboard">
                                                                <i class="bi @(_copiedDataId == data.Id ? "bi-check-lg" : "bi-clipboard")"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <p class="text-muted mb-0 small"><i class="bi bi-inbox me-2"></i>No data recorded for this connection</p>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox display-4"></i>
                <p class="mt-3 mb-0">No connections found in the selected date range</p>
                @if (Filter.HasAnyFilter)
                {
                    <button class="btn btn-outline-primary btn-sm mt-2" @onclick="ClearFilters">
                        <i class="bi bi-x-circle me-1"></i>Clear filters
                    </button>
                }
            </div>
        }
    </div>
</div>

<!-- Country Picker Popup -->
@if (_showCountryPicker)
{
    <div class="details-popup-backdrop" @onclick="CloseCountryPicker"></div>
    <div class="details-popup shadow-lg" tabindex="0" @ref="_countryPickerRef"
         style="top:@(_countryPickerY)px; left:@(_countryPickerX)px; min-width: 220px; max-width: 280px; outline: none;"
         @onclick:stopPropagation="true" @onkeydown="OnCountryKeyDown">
        <div class="details-popup-header">
            <span class="fw-semibold small"><i class="bi bi-globe me-1"></i>Filter by Country</span>
            @if (!string.IsNullOrEmpty(_countrySearch))
            {
                <span class="badge bg-primary-subtle text-primary border border-primary-subtle" style="font-size: 0.65rem;">@_countrySearch</span>
            }
            <button class="btn btn-sm btn-close" @onclick="CloseCountryPicker"></button>
        </div>
        <div style="max-height: 280px; overflow-y: auto; font-size: 0.75rem;">
            @if (!FilteredCountries.Any() && !string.IsNullOrEmpty(_countrySearch))
            {
                <div class="px-3 py-2 text-muted fst-italic">No matches</div>
            }
            else
            {
                <button class="dropdown-item px-3 py-1 @(string.IsNullOrEmpty(Filter.CountryCode) ? "active" : "")" @onclick="() => SelectCountry(string.Empty)">All</button>
                <hr class="my-1" />
                @foreach (var country in FilteredCountries)
                {
                    var cc = country.CountryCode;
                    <button class="dropdown-item px-3 py-1 @(Filter.CountryCode == cc ? "active" : "")" @onclick="() => SelectCountry(cc)">
                        <img src="https://flagcdn.com/w20/@(cc.ToLowerInvariant()).png" width="14" height="10" alt="@cc" loading="lazy" class="me-1" />
                        @(string.IsNullOrEmpty(country.CountryName) ? cc : country.CountryName)
                        <span class="text-muted ms-1">(@cc)</span>
                    </button>
                }
            }
        </div>
    </div>
}

<!-- IP Details Popup -->
@if (_selectedIP != null || _selectedPort != null)
{
    <div class="details-popup-backdrop" @onclick="CloseAllPopups"></div>
}

@if (_selectedIP != null)
{
    <div class="details-popup shadow-lg" style="top:@(_popoverY)px; left:@(_popoverX)px;" @onclick:stopPropagation="true">
        <div class="details-popup-header">
            <span class="fw-semibold small">
                <i class="bi bi-info-circle me-1"></i>@_selectedIP
                <a href="https://www.abuseipdb.com/check/@_selectedIP" target="_blank" rel="noopener noreferrer" class="ms-1 text-decoration-none" title="View on AbuseIPDB">
                    <i class="bi bi-box-arrow-up-right"></i>
                </a>
            </span>
            <button class="btn btn-sm btn-close" @onclick="CloseIPDetails"></button>
        </div>
        <div class="details-popup-body">
            @if (_selectedIPDetails != null)
            {
                <table class="table table-sm table-borderless mb-0">
                    <tbody>
                        <tr>
                            <td class="text-muted fw-semibold">Hits</td>
                            <td class="fw-bold">@_selectedIPDetails.Hits.ToString("N0")</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">Last Seen</td>
                            <td>@(_selectedIPDetails.LastConnectionTime?.ToString("MMM dd, yyyy HH:mm") ?? "—")</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">Blacklisted</td>
                            <td>
                                @if (_selectedIPDetails.IsBlacklisted)
                                {
                                    <span class="badge bg-danger">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">No</span>
                                }
                            </td>
                        </tr>
                        @if (_selectedIPDetails.HasAbuseData)
                        {
                            <tr><td colspan="2"><hr class="my-1" /></td></tr>
                            <tr>
                                <td class="text-muted fw-semibold">Abuse Score</td>
                                <td><span class="badge @GetAbuseConfidenceBadgeClass(_selectedIPDetails.AbuseConfidence!.Value)">@(_selectedIPDetails.AbuseConfidence)%</span></td>
                            </tr>
                            @if (!string.IsNullOrEmpty(_selectedIPDetails.CountryName))
                            {
                                <tr>
                                    <td class="text-muted fw-semibold">Country</td>
                                    <td>@_selectedIPDetails.CountryName</td>
                                </tr>
                            }
                            @if (!string.IsNullOrEmpty(_selectedIPDetails.ISP))
                            {
                                <tr>
                                    <td class="text-muted fw-semibold">ISP</td>
                                    <td>@_selectedIPDetails.ISP</td>
                                </tr>
                            }
                            @if (!string.IsNullOrEmpty(_selectedIPDetails.Domain))
                            {
                                <tr>
                                    <td class="text-muted fw-semibold">Domain</td>
                                    <td><a href="https://@_selectedIPDetails.Domain" target="_blank" rel="noopener noreferrer">@_selectedIPDetails.Domain</a></td>
                                </tr>
                            }
                            @if (!string.IsNullOrEmpty(_selectedIPDetails.UsageType))
                            {
                                <tr>
                                    <td class="text-muted fw-semibold">Usage</td>
                                    <td>@_selectedIPDetails.UsageType</td>
                                </tr>
                            }
                            <tr>
                                <td class="text-muted fw-semibold">Reports</td>
                                <td>@(_selectedIPDetails.TotalReports?.ToString("N0") ?? "0") from @(_selectedIPDetails.DistinctUserCount?.ToString("N0") ?? "0") users</td>
                            </tr>
                            @if (_selectedIPDetails.LastReportedAt != null)
                            {
                                <tr>
                                    <td class="text-muted fw-semibold">Last Report</td>
                                    <td>@_selectedIPDetails.LastReportedAt.Value.ToString("MMM dd, yyyy")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="2" class="text-muted fst-italic">No AbuseIPDB data</td></tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

<!-- Port Details Popup -->
@if (_selectedPort != null)
{
    <div class="details-popup shadow-lg" style="top:@(_popoverY)px; left:@(_popoverX)px;" @onclick:stopPropagation="true">
        <div class="details-popup-header">
            <span class="fw-semibold small">
                <i class="bi bi-ethernet me-1"></i>Port @_selectedPort
                <a href="https://www.iana.org/assignments/service-names-port-numbers/service-names-port-numbers.xhtml?search=@_selectedPort" target="_blank" rel="noopener noreferrer" class="ms-1 text-decoration-none" title="View on IANA">
                    <i class="bi bi-box-arrow-up-right"></i>
                </a>
            </span>
            <button class="btn btn-sm btn-close" @onclick="ClosePortDetails"></button>
        </div>
        <div class="details-popup-body">
            @if (_selectedPortInfo != null)
            {
                <table class="table table-sm table-borderless mb-0">
                    <tbody>
                        <tr>
                            <td class="text-muted fw-semibold">Service</td>
                            <td class="fw-bold">@_selectedPortInfo.ServiceName</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">Description</td>
                            <td>@_selectedPortInfo.Description</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">Protocol</td>
                            <td><span class="badge bg-secondary">@_selectedPortInfo.Protocol</span></td>
                        </tr>
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted fst-italic mb-0 py-1">No IANA registration found for this port.</p>
            }
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public PagedResult<Connection>? PagedConnections { get; set; }
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public ConnectionFilter Filter { get; set; } = new();
    [Parameter] public List<CountryInfo> DistinctCountries { get; set; } = [];
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
    [Parameter] public EventCallback<ConnectionFilter> OnFilterChanged { get; set; }
    [Parameter] public EventCallback<string> OnSortChanged { get; set; }

    private Dictionary<string, List<ConnectionData>?> _expandedSessions = new();
    private string? _loadingSessionId;
    private bool _isExpandingAll;
    private long? _copiedDataId;

    // Popup state
    private int _popoverX;
    private int _popoverY;
    private string? _selectedIP;
    private IPDetails? _selectedIPDetails;
    private long? _selectedPort;

    // Country picker state
    private bool _showCountryPicker;
    private int _countryPickerX;
    private int _countryPickerY;
    private string _countrySearch = string.Empty;
    private ElementReference _countryPickerRef;

    private IEnumerable<CountryInfo> FilteredCountries => string.IsNullOrWhiteSpace(_countrySearch)
        ? DistinctCountries
        : DistinctCountries.Where(c =>
            c.CountryCode.Contains(_countrySearch, StringComparison.OrdinalIgnoreCase) ||
            c.CountryName.Contains(_countrySearch, StringComparison.OrdinalIgnoreCase));
    private PortInfo? _selectedPortInfo;

    private IEnumerable<int> GetPageNumbers()
    {
        if (PagedConnections == null) yield break;
        int start = Math.Max(1, CurrentPage - 2);
        int end = Math.Min(PagedConnections.TotalPages, CurrentPage + 2);
        for (int i = start; i <= end; i++)
            yield return i;
    }

    private string SortIcon(string column)
    {
        var activeColumn = Filter.SortColumn ?? nameof(Connection.ConnectionTime);
        if (activeColumn != column)
            return "sort-icon-inactive";

        return (Filter.SortColumn is null || Filter.SortDescending)
            ? "sort-icon-desc"
            : "sort-icon-asc";
    }

    private async Task ApplyFilter(Action<ConnectionFilter> update)
    {
        update(Filter);
        await OnFilterChanged.InvokeAsync(Filter);
    }

    private async Task ClearFilters()
    {
        Filter = new();
        await OnFilterChanged.InvokeAsync(Filter);
    }

    private async Task ToggleRowExpand(string? sessionId)
    {
        if (string.IsNullOrEmpty(sessionId)) return;

        if (_expandedSessions.ContainsKey(sessionId))
        {
            _expandedSessions.Remove(sessionId);
            return;
        }

        _loadingSessionId = sessionId;
        _expandedSessions[sessionId] = null;
        StateHasChanged();

        try
        {
            _expandedSessions[sessionId] = await DashboardService.GetConnectionDataAsync(sessionId);
        }
        catch
        {
            _expandedSessions.Remove(sessionId);
        }
        finally
        {
            _loadingSessionId = null;
            StateHasChanged();
        }
    }

    private async Task ExpandAll()
    {
        if (PagedConnections == null) return;
        _isExpandingAll = true;
        StateHasChanged();
        await Task.Yield();

        try
        {
            foreach (var sessionId in PagedConnections.SessionsWithData.Where(s => !_expandedSessions.ContainsKey(s)).ToList())
            {
                try { _expandedSessions[sessionId] = await DashboardService.GetConnectionDataAsync(sessionId); }
                catch { }
            }
        }
        finally
        {
            _isExpandingAll = false;
            StateHasChanged();
        }
    }

    private void CollapseAll() => _expandedSessions.Clear();

    public void ClearExpandedSessions() => _expandedSessions.Clear();

    private async Task ShowIPDetailsAsync(string ipAddress, string anchorId)
    {
        ClosePortDetails();
        if (_selectedIP == ipAddress) { CloseIPDetails(); return; }

        var pos = await JS.InvokeAsync<int[]>("getElementPosition", anchorId);
        if (pos is { Length: 2 }) { _popoverY = pos[0]; _popoverX = pos[1]; }

        IPDetails? details;
        try { details = await DashboardService.GetIPDetailsAsync(ipAddress); }
        catch { details = new IPDetails { IPAddress = ipAddress }; }

        _selectedIP = ipAddress;
        _selectedIPDetails = details;
        StateHasChanged();
    }

    private async Task ShowPortDetailsAsync(long port, string anchorId)
    {
        CloseIPDetails();
        if (_selectedPort == port) { ClosePortDetails(); return; }

        var pos = await JS.InvokeAsync<int[]>("getElementPosition", anchorId);
        if (pos is { Length: 2 }) { _popoverY = pos[0]; _popoverX = pos[1]; }

        PortInfo? info = null;
        try { info = await PortLookup.GetPortInfoAsync(port); }
        catch { }

        _selectedPort = port;
        _selectedPortInfo = info;
        StateHasChanged();
    }

    private async Task ToggleCountryPickerAsync()
    {
        if (_showCountryPicker) { CloseCountryPicker(); return; }

        var pos = await JS.InvokeAsync<int[]>("getElementPosition", "country-filter-btn");
        if (pos is { Length: 2 }) { _countryPickerY = pos[0]; _countryPickerX = pos[1]; }

        _countrySearch = string.Empty;
        _showCountryPicker = true;
        StateHasChanged();
        await Task.Yield();
        await _countryPickerRef.FocusAsync();
    }

    private async Task OnCountryKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") { CloseCountryPicker(); return; }
        if (e.Key == "Enter")
        {
            var match = FilteredCountries.FirstOrDefault();
            await SelectCountry(match?.CountryCode ?? string.Empty);
            return;
        }
        if (e.Key == "Backspace") { if (_countrySearch.Length > 0) _countrySearch = _countrySearch[..^1]; return; }
        if (e.Key.Length != 1) return;

        _countrySearch += e.Key;
    }

    private async Task SelectCountry(string countryCode)
    {
        _showCountryPicker = false;
        await ApplyFilter(f => f.CountryCode = countryCode);
    }

    private void CloseCountryPicker() => _showCountryPicker = false;

    private void CloseIPDetails() { _selectedIP = null; _selectedIPDetails = null; }
    private void ClosePortDetails() { _selectedPort = null; _selectedPortInfo = null; }
    private void CloseAllPopups() { CloseIPDetails(); ClosePortDetails(); CloseCountryPicker(); }

    private static string GetAbuseConfidenceBadgeClass(long confidence) => confidence switch
    {
        >= 75 => "bg-danger",
        >= 50 => "bg-warning text-dark",
        >= 25 => "bg-info text-dark",
        _ => "bg-success"
    };

    private async Task CopyDataAsync(ConnectionData data)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", data.Data);
        _copiedDataId = data.Id;
        StateHasChanged();

        _ = Task.Delay(2000).ContinueWith(_ =>
        {
            _copiedDataId = null;
            InvokeAsync(StateHasChanged);
        });
    }
}
