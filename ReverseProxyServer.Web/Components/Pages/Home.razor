@page "/"
@using ReverseProxyServer.Web.Components.Dashboard
@rendermode InteractiveServer

<PageTitle>Dashboard - Reverse Proxy Server</PageTitle>

<!-- Header with Date Range -->
<div class="dashboard-header mb-1">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div>
            <h1 class="h5 mb-0 fw-bold">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </h1>
            <p class="text-muted mb-0 small d-none d-md-block">Monitor your reverse proxy connections in real-time</p>
        </div>
        <div class="date-range-picker">
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-white"><i class="bi bi-calendar3"></i></span>
                <span class="input-group-text bg-white text-muted" style="font-size:0.7rem;">From</span>
                <input type="datetime-local" class="form-control" @bind="_fromDate" @bind:format="yyyy-MM-ddTHH:mm:ss" step="1" />
                <span class="input-group-text bg-white text-muted" style="font-size:0.7rem;">To</span>
                <input type="datetime-local" class="form-control" @bind="_toDate" @bind:format="yyyy-MM-ddTHH:mm:ss" step="1" />
                <button class="btn btn-primary" @onclick="() => LoadAllDataAsync()" disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                    }
                    else
                    {
                        <i class="bi bi-arrow-clockwise"></i>
                    }
                </button>
                <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" disabled="@_isLoading">
                    Quick
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="#" @onclick="SetToday" @onclick:preventDefault>Today</a></li>
                    <li><a class="dropdown-item" href="#" @onclick="SetYesterday" @onclick:preventDefault>Yesterday</a></li>
                    <li><a class="dropdown-item" href="#" @onclick="SetThisWeek" @onclick:preventDefault>This Week</a></li>
                    <li><a class="dropdown-item" href="#" @onclick="SetThisMonth" @onclick:preventDefault>This Month</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item" href="#" @onclick="SetThisYear" @onclick:preventDefault>This year</a></li>
                    <li><a class="dropdown-item" href="#" @onclick="SetLastYear" @onclick:preventDefault>Last year</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-2">
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "statistics" ? "active" : "")" @onclick='() => SetTabAsync("statistics")'>
            <i class="bi bi-bar-chart me-1"></i>Statistics
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "realtime" ? "active" : "")" @onclick='() => SetTabAsync("realtime")'>
            <i class="bi bi-broadcast me-1"></i>Realtime
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "worldview" ? "active" : "")" @onclick='() => SetTabAsync("worldview")'>
            <i class="bi bi-globe-americas me-1"></i>World View
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "search" ? "active" : "")" @onclick='() => SetTabAsync("search")'>
            <i class="bi bi-search me-1"></i>Search
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "about" ? "active" : "")" @onclick='() => SetTabAsync("about")'>
            <i class="bi bi-info-circle me-1"></i>About
        </button>
    </li>
</ul>

@if (_error != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

<!-- Tab Content -->
@if (_activeTab == "statistics")
{
    <StatCards ConnectionStats="_connectionStats"
              UniqueIPs="_uniqueIPs"
              UniquePorts="_uniquePorts"
              BlacklistedIPs="_blacklistedIPs"
              TopConnection="_topConnection"
              BandwidthStats="_bandwidthStats"
              IsLoading="_isLoading"
              OnTopConnectionClicked="FilterByIPAsync" />

    <ConnectionLog @ref="_connectionLogRef"
                   PagedConnections="_pagedConnections"
                   CurrentPage="_currentPage"
                   IsLoading="_isLoadingConnections"
                   Filter="_filter"
                   DistinctCountries="_distinctCountries"
                   OnPageChanged="HandlePageChanged"
                   OnFilterChanged="HandleFilterChanged"
                   OnSortChanged="HandleSortChanged" />
}

@if (_activeTab == "realtime")
{
    <RealtimeTab Events="_liveEvents"
                 IsConnected="_hubConnected"
                 AutoScroll="_autoScroll"
                 OnClear="ClearLiveEvents"
                 OnTogglePause="TogglePauseAutoScroll" />
}

<WorldViewTab Visible="@(_activeTab == "worldview")"
              IsLoading="_isLoadingWorldView"
              DarkStyle="_darkMapStyle"
              RealtimeEnabled="_realtimeWorldView"
              CountryCounts="_countryCounts"
              OnToggleStyle="ToggleMapStyleAsync"
              OnToggleRealtime="ToggleRealtimeWorldViewAsync" />

@if (_activeTab == "search")
{
    <SearchTab SearchResults="_searchResults"
               CurrentPage="_searchPage"
               SearchTerm="@_searchTerm"
               TotalRecords="_totalSearchableRecords"
               FocusOnRender="true"
               UseDateRange="_searchUseDateRange"
               FromDate="_fromDate"
               ToDate="_toDate"
               OnSearch="HandleSearchAsync"
               OnPageChanged="HandleSearchPageChanged"
               OnSortChanged="HandleSearchSortChanged"
               OnDateRangeToggled="HandleSearchDateRangeToggled" />
}

@if (_activeTab == "about")
{
    <AboutTab />
}

<!-- Debug Panel (Ctrl+Shift+D) -->
@if (_showDbSwitcher)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);" @onclick="() => _showDbSwitcher = false">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title mb-0"><i class="bi bi-gear me-2"></i>Debug Panel</h6>
                    <button type="button" class="btn-close" @onclick="() => _showDbSwitcher = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small mb-1"><i class="bi bi-database me-1"></i>Database</label>
                        <div class="d-grid gap-2">
                            <button class="btn btn-sm @(_activeDb == "Release" ? "btn-primary" : "btn-outline-secondary") text-start"
                                    @onclick='() => SwitchDatabaseAsync("Release")'>
                                <i class="bi bi-box-seam me-2"></i>Release
                                <br /><small class="text-opacity-75" style="font-size:0.65rem;">@DatabaseSettings.CurrentValue.ReleasePath</small>
                            </button>
                            <button class="btn btn-sm @(_activeDb == "Debug" ? "btn-primary" : "btn-outline-secondary") text-start"
                                    @onclick='() => SwitchDatabaseAsync("Debug")'>
                                <i class="bi bi-bug me-2"></i>Debug
                                <br /><small class="text-opacity-75" style="font-size:0.65rem;">@DatabaseSettings.CurrentValue.DebugPath</small>
                            </button>
                        </div>
                    </div>
                    <hr class="my-2" />
                    <div class="mb-1">
                        <label class="form-label fw-semibold small mb-1"><i class="bi bi-list-ol me-1"></i>Connection Log Page Size</label>
                        <div class="d-flex align-items-center gap-2">
                            @foreach (var size in new[] { 25, 50, 100, 200 })
                            {
                                <button class="btn btn-sm @(_pageSize == size ? "btn-primary" : "btn-outline-secondary")"
                                        @onclick="() => ChangePageSizeAsync(size)">@size</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Scroll to top button -->
<button class="btn btn-primary btn-scroll-top shadow" id="scrollTopBtn"
        onclick="window.scrollTo({top:0,behavior:'smooth'})" title="Back to top">
    <i class="bi bi-arrow-up"></i>
</button>
